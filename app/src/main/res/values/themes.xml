<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ExpressFood" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/text_on_green</item>
        <item name="colorSecondary">@color/green_light</item>
        <item name="colorSecondaryVariant">@color/green_dark</item>
        <item name="colorOnSecondary">@color/text_on_green</item>
        <item name="android:colorBackground">@color/background_white</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/green_dark</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.ExpressFood.Login" parent="Theme.ExpressFood">
        <item name="android:windowBackground">@color/background_login</item>
        <item name="android:statusBarColor">@color/green_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.ExpressFood.Main" parent="Theme.ExpressFood">
        <item name="android:statusBarColor">@color/green_dark</item>
    </style>

</resources>